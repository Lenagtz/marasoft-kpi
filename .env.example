# =============================================================================
# Marasoft KPI ETL — Configuration d'environnement
# Copiez ce fichier : cp .env.example .env  puis renseignez les valeurs
# =============================================================================

# ── API Marasoft (OBLIGATOIRE) ────────────────────────────────────────────────
MARASOFT_BASE_URL=https://external02.marad.ms
MARASOFT_API_KEY=votre_cle_api_ici

# Timeout HTTP en secondes
MARASOFT_TIMEOUT=30

# Nombre de tentatives en cas d'erreur réseau
MARASOFT_MAX_RETRIES=3

# Délai de base entre tentatives (exponentiel : 2s, 4s, 8s...)
MARASOFT_RETRY_DELAY=2.0

# Requêtes par seconde max (respecter les limites API)
MARASOFT_RATE_LIMIT_RPS=5

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://marasoft_etl:motdepasse@localhost:5432/marasoft_kpi
DB_POOL_SIZE=5

# ── Charge incrémentale ───────────────────────────────────────────────────────
# Nombre de jours en arrière pour le mode delta (défaut: 7)
ETL_DELTA_DAYS=7

# ── Seuils KPI (jours avant expiration) ──────────────────────────────────────
CERT_EXPIRY_WARNING_DAYS=30
CERT_EXPIRY_CRITICAL_DAYS=7

# Heures de repos minimum par jour (MLC 2006 : 10h)
REST_HOURS_MIN_DAILY=10.0

# Stock minimum pièces par défaut si non défini dans l'API
PARTS_MIN_STOCK=2

# Fenêtre d'anticipation rapports QHSE (jours)
QHSE_DUE_BEFORE_DAYS=30

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
